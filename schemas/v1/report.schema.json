{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/report.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.report",
  "title": "LoopEngineer Report",
  "description": "A locator-backed agent loop report artifact produced by a worker, scheduler, or watcher.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "report_id",
    "report_type",
    "role",
    "status",
    "version",
    "producer",
    "created_at",
    "summary",
    "next_action"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.report"
    },
    "report_id": {
      "type": "string",
      "pattern": "^report-[A-Za-z0-9._-]+$"
    },
    "report_type": {
      "enum": [
        "instruction_ack",
        "startup_report",
        "progress_update",
        "blocker_update",
        "completion_result",
        "gate_wait",
        "routing_missing",
        "correction_result"
      ]
    },
    "role": {
      "enum": [
        "worker",
        "scheduler",
        "watcher"
      ]
    },
    "status": {
      "enum": [
        "acknowledged",
        "running",
        "blocked",
        "waiting",
        "completed",
        "failed"
      ]
    },
    "version": {
      "$ref": "#/$defs/version"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "worker",
            "scheduler",
            "watcher"
          ]
        },
        "thread_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "instruction_id": {
      "type": "string",
      "minLength": 1
    },
    "report_to_thread_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/locator"
      }
    },
    "next_action": {
      "$ref": "#/$defs/nextAction"
    }
  },
  "$defs": {
    "version": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "productVersion",
        "protocolVersion",
        "schemaVersion",
        "skillContractVersion"
      ],
      "properties": {
        "productVersion": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
        },
        "protocolVersion": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "const": "1.0"
        },
        "skillContractVersion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "locator"
      ],
      "properties": {
        "kind": {
          "enum": [
            "file",
            "github",
            "artifact",
            "command"
          ]
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "consumed": {
          "type": "boolean"
        }
      }
    },
    "nextAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "action",
        "status"
      ],
      "properties": {
        "owner": {
          "enum": [
            "worker",
            "scheduler",
            "watcher",
            "user",
            "external"
          ]
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "required",
            "blocked",
            "waiting",
            "none"
          ]
        }
      }
    }
  }
}
